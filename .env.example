# Environment Variables Example
# Copy this file to .env and update with your values

# Application
VITE_APP_NAME=Lumière
VITE_APP_DESCRIPTION=Premium intimate wellness products

# Development
VITE_PORT=5173
VITE_HOST=localhost

# Production
NODE_ENV=production
PORT=3000

# API (if you have a backend)
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Analytics (optional)
VITE_GA_ID=
VITE_MIXPANEL_TOKEN=

# Email (for newsletter)
VITE_SENDGRID_API_KEY=

# Security
VITE_SENTRY_DSN=
